# Required
NOTION_TOKEN=secret_your_notion_integration_token

# AI Provider
AI_PROVIDER_TYPE=deterministic
# AI_ENDPOINT=http://localhost:11434
# AI_API_KEY=
# AI_MODEL_NAME=llama3.1

# Model Tuning
AI_TEMPERATURE=0.2
AI_TIMEOUT_MS=45000
AI_MAX_RETRIES=2
AI_FALLBACK_TO_DETERMINISTIC=true

# Embeddings
EMBEDDING_PROVIDER=none
EMBEDDING_ENDPOINT=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_SIMILARITY_THRESHOLD=0.92
EMBEDDING_INDEX_PATH=.auto-doc-mcp/embeddings.json

# Publishing
PUBLISHING_MODE=balanced
AUTO_PUBLISH_THRESHOLD=90

# Runner
RUNNER_TICK_MS=30000
RUNNER_MAX_CONCURRENT=4
RUNNER_MAX_FAILURES=5
RUNNER_CIRCUIT_RESET_MS=300000
RUNNER_TARGET_TIMEOUT_MS=60000

# Security and Transport
STATE_ENCRYPTION_KEY=change-this-to-a-random-32-char-string
CORS_ALLOWED_ORIGINS=http://localhost,https://verdent.ai,https://v0.dev,https://bolt.new,https://lovable.dev
AUTO_DOC_HTTP_HOST=127.0.0.1
AUTO_DOC_HTTP_PORT=3741

# Self-hosted deployment stack (optional)
GITHUB_WEBHOOK_SECRET=
AI_SESSION_WEBHOOK_SECRET=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_BIFROST_HOSTNAME=bifrost.example.com
CLOUDFLARE_MCP_HOSTNAME=mcp.example.com
TAILSCALE_AUTH_KEY=