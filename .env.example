# Core
NOTION_TOKEN=secret_your_notion_integration_token_here
NOTION_PARENT_PAGE_ID=
RUN_LIVE_NOTION_TESTS=false

# Server / transport
AUTO_DOC_HTTP_HOST=127.0.0.1
AUTO_DOC_HTTP_PORT=3000
AUTO_DOC_LOG_LEVEL=info
AUTO_DOC_ALLOW_UNAUTHENTICATED_SSE=true
AUTO_DOC_RUNTIME_MODE=mcp
CORS_ALLOWED_ORIGINS=http://localhost,https://bifrost.giscop.com,https://mcp.giscop.com

# AI provider
AI_PROVIDER_TYPE=bifrost
AI_ENDPOINT=http://bifrost-gateway:8080/v1
AI_API_KEY=ollama
AI_MODEL_NAME=openai/llama3.2:3b-instruct-q4_K_M
AI_FALLBACK_MODEL_1=openai/qwen2.5:3b-instruct-q4_K_M
AI_FALLBACK_MODEL_2=openai/gemma2:2b-instruct-q4_K_M
AI_FALLBACK_MODEL_3=openai/llama3.1:8b-instruct-q4_K_M
AI_CLOUD_FALLBACK_MODEL=
AI_TEMPERATURE=0.2
AI_TIMEOUT_MS=45000
AI_MAX_RETRIES=2
AI_FALLBACK_TO_DETERMINISTIC=true
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
BIFROST_ENDPOINT=http://bifrost-gateway:8080
BIFROST_VIRTUAL_KEY=sk-bf-your-virtual-key-from-bifrost-governance-section

# Embeddings
EMBEDDING_PROVIDER=none
EMBEDDING_ENDPOINT=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_SIMILARITY_THRESHOLD=0.92
EMBEDDING_INDEX_PATH=.auto-doc-mcp/embeddings.json

# Publishing
PUBLISHING_MODE=balanced
AUTO_PUBLISH_THRESHOLD=90

# Runner
RUNNER_TICK_MS=30000
RUNNER_MAX_CONCURRENT=4
RUNNER_MAX_FAILURES=5
RUNNER_CIRCUIT_RESET_MS=300000
RUNNER_TARGET_TIMEOUT_MS=60000
AUTO_DOC_RUNNER_POLL_INTERVAL_MS=
AUTO_DOC_RUNNER_TARGETS=
AUTO_DOC_RUNNER_PROJECT_ID=
AUTO_DOC_RUNNER_REPO_PATH=
AUTO_DOC_RUNNER_MODE=last_commit
AUTO_DOC_RUNNER_RELEASE_AUTOMATION=
AUTO_DOC_RUNNER_RELEASE_AUDIENCE=
AUTO_DOC_RUNNER_RELEASE_PACKAGE_FORMAT=
AUTO_DOC_RUNNER_RELEASE_PR_URL=
AUTO_DOC_RUNNER_RELEASE_PDF_OUTPUT_PATH=
AUTO_DOC_RUNNER_RELEASE_LOCAL_DOCS_OUTPUT_PATH=
AUTO_DOC_RUNNER_RELEASE_HELP_CENTER_OUTPUT_PATH=
AUTO_DOC_RUNNER_TRACE_ID=
SELF_DOC_PROJECT_ID=
SELF_DOC_REPO_PATH=
SELF_DOC_RUNNER_MODE=last_commit

# Security / storage
STATE_ENCRYPTION_KEY=change-this-to-a-random-32-char-string-in-production
GITHUB_WEBHOOK_SECRET=
AI_SESSION_WEBHOOK_SECRET=
WEBHOOK_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_REPLAY_TTL_MS=600000

# Infrastructure
POSTGRES_PASSWORD=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_BIFROST_HOSTNAME=bifrost.giscop.com
CLOUDFLARE_MCP_HOSTNAME=mcp.giscop.com
TAILSCALE_AUTH_KEY=

# Prompt repository / Bifrost sync
AUTO_DOC_ANALYZER_PROMPT_NAME=auto-doc-analyzer
AUTO_DOC_REVIEWER_PROMPT_NAME=auto-doc-reviewer
AUTO_DOC_GAP_FILLER_PROMPT_NAME=auto-doc-gap-filler
AUTO_DOC_STALENESS_UPDATER_PROMPT_NAME=auto-doc-staleness-updater
BIFROST_PROMPT_REPO_ENDPOINT=
BIFROST_PROMPT_REPO_API_KEY=
BIFROST_BASIC_AUTH_USERNAME=
BIFROST_BASIC_AUTH_PASSWORD=
