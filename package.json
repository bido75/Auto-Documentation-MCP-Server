{
  "name": "auto-docs-notion-mcp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "auto-docs-notion-mcp": "./build/src/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:live-notion": "vitest run tests/integration/live-notion.integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node build/src/index.js",
    "cli": "node build/src/cli/index.js",
    "prompts:sync": "node scripts/sync-prompt-repo.mjs",
    "prompts:sync:dry-run": "node scripts/sync-prompt-repo.mjs --dry-run",
    "failover:smoke": "node scripts/forced-cloud-failover-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@notionhq/client": "^2.2.15",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "openai": "^6.39.1",
    "playwright": "^1.54.2",
    "simple-git": "^3.27.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "nock": "^13.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
