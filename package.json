{
  "name": "auto-docs-notion-mcp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "auto-docs-notion-mcp": "./build/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:live-notion": "vitest run tests/integration/live-notion.integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node build/index.js",
    "prompts:sync": "node scripts/sync-prompt-repo.mjs",
    "prompts:sync:dry-run": "node scripts/sync-prompt-repo.mjs --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@notionhq/client": "^2.2.15",
    "playwright": "^1.54.2",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "nock": "^13.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
