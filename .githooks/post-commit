#!/usr/bin/env sh
set -eu

branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" != "main" ]; then
  exit 0
fi

# Auto-push latest commit on main and show actionable failures.
if ! git push -u origin main; then
  echo "[auto-push] push failed, retrying once in 2 seconds..." >&2
  sleep 2
  git push -u origin main
fi
